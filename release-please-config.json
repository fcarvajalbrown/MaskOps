{
  "packages": {
    ".": {
      "release-type": "python",
      "skip-github-release": true,
      "changelog-path": "docs/CHANGELOG.md",
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "generic",
          "path": "src/lib.rs"
        }
      ]
    }
  }
}
