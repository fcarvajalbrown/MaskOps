{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/hooks/release_guard.py",
            "if": "Bash(git push*)"
          },
          {
            "type": "command",
            "command": "python tools/hooks/release_guard.py",
            "if": "Bash(git tag*)"
          },
          {
            "type": "command",
            "command": "python tools/hooks/release_guard.py",
            "if": "Bash(gh release create*)"
          },
          {
            "type": "command",
            "command": "python tools/hooks/release_guard.py",
            "if": "Bash(gh pr create*)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/social/devto_reminder.py"
          },
          {
            "type": "command",
            "command": "python tools/hooks/stale_check.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"Rust file changed — re-run maturin develop --release before running tests.\"}'",
            "if": "Edit(*.rs)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"Rust file changed — re-run maturin develop --release before running tests.\"}'",
            "if": "Write(*.rs)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"maturin build complete — run: python tests/generate_fixtures.py && pytest tests/ -v\"}'",
            "if": "Bash(maturin develop*)"
          }
        ]
      }
    ]
  }
}
